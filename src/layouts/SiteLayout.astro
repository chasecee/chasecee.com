---
import { ClientRouter, fade } from "astro:transitions";
import { Font } from "astro:assets";
import SanityVisualEditing from "@/src/components/sanity/SanityVisualEditing";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Work - Chase Cee",
  description = "Chase Cee is a designer and developer in Salt Lake City building excellent web products front to back, from brand and UI design to full-stack engineering.",
  ogImage = "/og/home.png",
} = Astro.props;

const draftMode = Astro.locals.draftMode === true;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const canonicalURL = new URL(pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Chase Cee" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/icons/site/favicon.ico" />
    <link rel="shortcut icon" href="/icons/site/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/icons/site/apple-touch-icon.png" />
    <Font cssVariable="--font-rubik" preload />
    <ClientRouter />
  </head>
  <body
    class={`font-sans w-full min-h-screen bg-neutral-100 dark:bg-neutral-900 text-neutral-900 dark:text-white ${draftMode ? "pt-10" : ""}`}
    transition:animate={fade({ duration: "0.2s" })}
  >
    {
      draftMode && (
        <div class="fixed h-4 inset-x-0 top-0 z-[100] flex items-center justify-center border-b border-amber-400/30 bg-amber-300/95 px-4 text-[.75rem] text-black dark:bg-amber-300">
          <span>Draft mode active: you are viewing unpublished content</span>
        </div>
      )
    }
    <slot />
    {draftMode && <SanityVisualEditing client:only="react" />}
    <script is:inline src="/_vercel/insights/script.js"></script>
    <script is:inline src="/_vercel/speed-insights/script.js"></script>
  </body>
</html>
