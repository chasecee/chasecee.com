---
import type { Music } from "@/types/Music";
import { withSanityImageParams } from "@/src/utils/sanityImageParams";

interface Props {
  items: Music[];
}

const { items } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 flex-nowrap gap-10 overflow-x-auto pb-10">
  {
    items.map((item) => (
      <article class="w-full shrink-0">
        <a
          href={`/music/${typeof item.slug === "string" ? item.slug : item.slug?.current}`}
          class="group block text-black no-underline dark:text-white"
        >
          <div class="relative overflow-hidden aspect-square">
            {item.albumArt ? (
              <img
                src={withSanityImageParams(item.albumArt, {
                  w: 900,
                  h: 900,
                  fit: "crop",
                  auto: "format",
                })}
                alt={item.albumArtAlt || `${item.albumName} by ${item.bandName}`}
                width={640}
                height={640}
                class="absolute inset-0 h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : null}
          </div>
          <span class="mt-3 inline-block text-base">
            <span class="font-bold">{item.bandName}</span>
            <span class="font-light opacity-40">
              &nbsp;-&nbsp;{item.albumName}
              {typeof item.releaseYear === "number" ? ` (${item.releaseYear})` : ""}
            </span>
          </span>
        </a>
      </article>
    ))
  }
</div>
