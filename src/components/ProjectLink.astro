---
import urlFor from "@/sanity/sanity.image";
import type { Project } from "@/types/Project";
import { previewPath } from "@/src/utils/previewPath";

interface Props {
  project: Project;
  direction: "next" | "prev";
  preview?: boolean;
}

const { project, direction, preview = false } = Astro.props;
---

<div class={`${direction}-post grow`}>
  <a
    href={previewPath(`/projects/${project.slug}`, preview)}
    data-sanity-edit-target={preview ? "" : undefined}
    class={`${
      direction === "prev" ? "flex-row" : "flex-row-reverse"
    } not-prose group relative flex items-center justify-between gap-4 overflow-hidden rounded-xl bg-gray-500/30 no-underline transition-colors hover:bg-gray-500/10`}
  >
    {
      project.image && (
        <div class="flex-none">
          <img
            src={urlFor(project.image).width(150).height(150).dpr(1.5).url()}
            alt={project.name}
            width={150}
            height={150}
            class="w-full flex-none transition-opacity group-hover:opacity-90"
          />
        </div>
      )
    }
    <div class="relative z-10 flex grow justify-center">
      <div class="flex flex-col items-start gap-1">
        <span class="text-sm opacity-50">
          {direction === "prev" ? "Previous Project" : "Next Project"}
        </span>
        <span class="text-2xl">{project.name}</span>
      </div>
    </div>
  </a>
</div>
