---
import urlFor from "@/sanity/sanity.image";
import type { Project } from "@/types/Project";

interface Props {
  project: Project;
  direction: "next" | "prev";
}

const { project, direction } = Astro.props;
const projectSlug =
  typeof project.slug === "string" ? project.slug : project.slug?.current;
const draftMode = Astro.locals.draftMode === true;
const showDraftBadge = draftMode && project.isDraft;
const draftRingClass = showDraftBadge
  ? "ring-2 ring-amber-300 ring-offset-2 ring-offset-neutral-100 dark:ring-offset-neutral-900"
  : "";
const featuredImageTransitionName = projectSlug
  ? `project-featured-image-${projectSlug}`
  : undefined;
const overlayTransitionName = projectSlug
  ? `project-hero-overlay-${projectSlug}`
  : undefined;
---

<div class={`${direction}-post grow`}>
  <a
    href={`/projects/${project.slug}`}
    class={`${
      direction === "prev" ? "flex-row" : "flex-row-reverse text-right"
    } not-prose group relative aspect-5/2 flex items-center justify-between gap-4 overflow-hidden rounded-xl no-underline transition-colors ${draftRingClass}`}
  >
    {showDraftBadge && (
      <span class="pointer-events-none absolute top-2 right-2 z-20 inline-flex rounded bg-amber-300 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-black">
        Draft
      </span>
    )}
    {
      project.image && (
        <div class="flex-none absolute inset-0 bg-black">
          <img
            src={urlFor(project.image).width(350).height(350).dpr(1.5).url()}
            alt={project.name}
            width={350}
            height={350}
            class="vt-image w-full h-full object-cover"
            transition:name={featuredImageTransitionName}
          />
          <div
            class="absolute inset-0 bg-black opacity-80 transition-opacity duration-300 group-hover:opacity-100"
            transition:name={overlayTransitionName}
          >
          </div>
        </div>
      )
    }
    <div class="relative z-10 flex grow justify-center">
      <div class="flex flex-col items-start gap-1">
        <span class="text-sm opacity-50">
          {direction === "prev" ? "Previous Project" : "Next Project"}
        </span>
        <span class="text-2xl">{project.name}</span>
      </div>
    </div>
  </a>
</div>
