---
import Header from "@/src/components/Header";
import WavyLine from "@/src/components/WavyLine";
import LucideIcon from "@/src/components/icons/LucideIcon.astro";
import { GithubIcon, LinkedInIcon } from "@/src/components/icons";
import { LUCIDE_ICONS } from "@/src/components/icons/lucide";

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`root min-h-screen w-full ${className} px-0 md:mt-0`}>
  <div class="relative z-0 container">
    <Header
      client:load
      transition:persist="site-header"
      activePath={Astro.url.pathname}
    />
    <main>
      <slot />
    </main>
    <footer id="contact" class="site-footer mt-16 border-t border-black/10 py-10 dark:border-white/10">
      <div class="prose flex max-w-3xl flex-col items-start gap-5">
        <div class="flex items-center gap-3">
          <h2 class="m-0 text-5xl sm:text-6xl my-0! grow">
            Let's talk
          </h2>
          <div class="shrin1">
            <WavyLine client:visible />
          </div>
        </div>
        
        <div class="m-0 mt-1 flex flex-wrap gap-3">
          <a
            href="https://github.com/chasecee/"
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose inline-flex items-center justify-center gap-x-2 rounded-[.25rem] border-0 px-4 py-2 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-[.125rem] ring-black/10 bg-black/5 dark:bg-white/5 dark:ring-white/30"
          >
            Github
            <GithubIcon size={18} />
          </a>
          <a
            href="https://www.linkedin.com/in/chasechristensen-1/"
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose inline-flex items-center justify-center gap-x-2 rounded-[.25rem] border-0 px-4 py-2 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-[.125rem] ring-black/10 bg-black/5 dark:bg-white/5 dark:ring-white/30"
          >
            LinkedIn
            <LinkedInIcon size={18} />
          </a>
          <a
            href="/ChaseChristensen-Resume-2025.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose inline-flex items-center justify-center gap-x-2 rounded-[.25rem] border-0 px-4 py-2 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-[.125rem] ring-black/10 bg-black/5 dark:bg-white/5 dark:ring-white/30"
          >
            Resume
            <LucideIcon icon={LUCIDE_ICONS.fileText} size={18} />
          </a>
        </div>
      </div>
      <div class="prose mt-10 max-w-none">
        <div class="flex w-full flex-col items-start gap-2 sm:flex-row sm:flex-nowrap sm:items-center sm:justify-between sm:gap-4">
          <p
            class="footer__text text-uppercase group m-0 flex flex-row items-center gap-[0.5ch] whitespace-nowrap"
          >
            Made with
            <LucideIcon
              icon={LUCIDE_ICONS.heart}
              size={24}
              class="text-2xl transition group-hover:scale-125 group-hover:text-red-400"
            />
            by
            <a href="/about">Chase Cee</a>
          </p>
          <p class="m-0 whitespace-nowrap text-black/50 dark:text-white/50">Copyright © 2011-2099</p>
        </div>
      </div>
    </footer>
  </div>
</div>
