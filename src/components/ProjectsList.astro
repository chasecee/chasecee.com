---
import type { Project } from "@/types/Project";
import generateColorPalette from "@/src/utils/colorUtils";
import CustomDashboardCard from "@/src/components/project-cards/CustomDashboardCard";
import urlFor from "@/sanity/sanity.image";
import { previewPath } from "@/src/utils/previewPath";
import { sanitizeProjectSvg } from "@/src/utils/sanitizeProjectSvg";

interface Props {
  projects: Project[];
  title?: string;
  columns?: number;
  preview?: boolean;
}

const { projects, title, columns = 4, preview = false } = Astro.props;

const getColumnClass = (cols: number): string => {
  switch (cols) {
    case 1:
      return "w-full";
    case 2:
      return "md:w-1/2";
    case 3:
      return "md:w-1/3";
    case 4:
      return "md:w-1/4";
    case 5:
      return "md:w-1/5";
    case 6:
      return "md:w-1/6";
    default:
      return "md:w-1/4";
  }
};

const getCardImageSizes = (cols: number): string => {
  switch (cols) {
    case 2:
      return "(min-width: 768px) 50vw, 80vw";
    case 3:
      return "(min-width: 768px) 33vw, 80vw";
    case 4:
      return "(min-width: 768px) 25vw, 80vw";
    case 5:
      return "(min-width: 768px) 20vw, 80vw";
    case 6:
      return "(min-width: 768px) 16vw, 80vw";
    default:
      return "(min-width: 768px) 25vw, 80vw";
  }
};

const getCardImageWidths = (cols: number): number[] => {
  switch (cols) {
    case 2:
      return [320, 480, 640, 800, 960];
    case 3:
      return [320, 480, 640, 800];
    case 4:
    case 5:
    case 6:
      return [240, 320, 480, 640];
    default:
      return [320, 480, 640, 800];
  }
};

const validProjects = projects.filter(
  (project) => project && project._id && project.name,
);

const cardImageWidths = getCardImageWidths(columns);
const cardImageSizes = getCardImageSizes(columns);
const cardImageMaxWidth = cardImageWidths.at(-1) ?? 640;
---

<div class="project-list">
  {title && <h2 class="mb-6 text-left text-xl font-bold">{title}</h2>}
  <div class="flex flex-nowrap gap-12 overflow-x-auto pb-10">
    {
      validProjects.map((project, index) => {
        const slugname =
          typeof project.slug === "string"
            ? project.slug
            : project.slug?.current;
        const featuredImageTransitionName = slugname
          ? `project-featured-image-${slugname}`
          : undefined;
        const overlayTransitionName = slugname
          ? `project-hero-overlay-${slugname}`
          : undefined;
        const displayType = project.displayType || "popup";
        const colorPalette = project.color?.hex
          ? generateColorPalette(project.color.hex)
          : null;
        const projectImage = project.image;
        const toCssRatio = (value: string) =>
          value.includes("/")
            ? value
                .split("/")
                .map((part) => part.trim())
                .join(" / ")
            : value;
        const desktopRatio = toCssRatio(
          project.aspectRatio?.desktop || "1/1",
        );
        const mobileRatio = toCssRatio(
          project.aspectRatio?.mobile || project.aspectRatio?.desktop || "1/1",
        );

        const projectTitle = (
          <div class="relative">
            <span class="mt-3 inline-block text-base">
              <span class="font-bold">{project.name}</span>
              {project.subtitle && (
                <span class="font-light opacity-40">
                  &nbsp;-&nbsp;{project.subtitle}
                </span>
              )}
            </span>
          </div>
        );

        if (displayType === "embed" && project.embedUrl) {
          return (
            <div
              class={`project-item ${getColumnClass(columns)} w-[80%] flex-shrink-0 project-${index + 1} project-${slugname}`}
            >
              <a
                href={previewPath(`/projects/${slugname}`, preview)}
                title={`See my work on ${project.name}`}
                class="group"
                data-sanity-edit-target={preview ? "" : undefined}
              >
                <div
                  class="project-embed relative w-full"
                  style={`--ar-desktop: ${desktopRatio}; --ar-mobile: ${mobileRatio};`}
                >
                  <iframe
                    src={project.embedUrl}
                    title={project.name}
                    class="pointer-events-none absolute inset-0 h-full w-full border-0"
                    loading="lazy"
                    tabindex="-1"
                    data-project-embed
                  />
                </div>
                {projectTitle}
              </a>
            </div>
          );
        }

        return (
          <div
            class={`project-item ${getColumnClass(columns)} w-[80%] flex-shrink-0 project-${index + 1} project-${slugname}`}
          >
            <a
              href={previewPath(`/projects/${slugname}`, preview)}
              title={`See my work on ${project.name}`}
              class="group"
              data-sanity-edit-target={preview ? "" : undefined}
            >
              {slugname === "loop-player" ? (
                <div class="relative h-0 overflow-hidden rounded-xl pt-[100%]">
                  <img
                    src="/img/loop-box.webp"
                    alt="Loop Player product packaging"
                    width={473}
                    height={473}
                    class="vt-image absolute inset-0 h-full w-full rounded-xl object-cover"
                    transition:name={featuredImageTransitionName}
                    loading="eager"
                    fetchpriority="high"
                  />
                  <div
                    class="pointer-events-none absolute inset-0 rounded-xl bg-black/45 opacity-0"
                    transition:name={overlayTransitionName}
                  />
                  {project.svgcode?.code && (
                    <div class="view-actor absolute inset-0 transition-transform delay-[25ms] duration-500 group-hover:scale-110 group-hover:duration-300">
                      <div
                        class="svg-parent absolute top-1/2 left-1/2 h-full w-[50%] -translate-x-1/2 -translate-y-1/2 text-white"
                        set:html={sanitizeProjectSvg(project.svgcode.code)}
                      />
                    </div>
                  )}
                </div>
              ) : slugname === "custom-dashboard" ? (
                <CustomDashboardCard
                  client:visible
                  project={project}
                  index={index}
                />
              ) : (
                <div class="relative h-0 overflow-hidden rounded-xl pt-[100%]">
                  {displayType === "background" && projectImage ? (
                    <img
                      src={urlFor(projectImage)
                        .width(cardImageMaxWidth)
                        .height(cardImageMaxWidth)
                        .fit("crop")
                        .dpr(1)
                        .url()}
                      srcset={cardImageWidths
                        .map(
                          (width) =>
                            `${urlFor(projectImage)
                              .width(width)
                              .height(width)
                              .fit("crop")
                              .dpr(1)
                              .url()} ${width}w`,
                        )
                        .join(", ")}
                      sizes={cardImageSizes}
                      alt={project.name}
                      width={cardImageMaxWidth}
                      height={cardImageMaxWidth}
                      class="vt-image absolute inset-0 h-full w-full rounded-xl object-cover"
                      transition:name={featuredImageTransitionName}
                      loading={index === 0 ? "eager" : "lazy"}
                      fetchpriority={index === 0 ? "high" : "auto"}
                      decoding="async"
                    />
                  ) : (
                    project.color?.hex && (
                      <div
                        class="absolute inset-0 rounded-xl"
                        style={{ backgroundColor: project.color.hex }}
                      />
                    )
                  )}

                  {displayType === "background" && projectImage && (
                    <div
                      class="pointer-events-none absolute inset-0 rounded-xl bg-black/45 opacity-0"
                      transition:name={overlayTransitionName}
                    />
                  )}

                  {displayType === "popup" && colorPalette && (
                    <div class="project-gradient-bg absolute inset-0 -top-10 -bottom-10 flex-col flex-nowrap gap-0 overflow-hidden rounded-xl opacity-[20%] transition-all duration-500">
                      {[
                        colorPalette.darkest,
                        colorPalette.darker,
                        colorPalette.main,
                        colorPalette.lighter,
                        colorPalette.lightest,
                      ].map((color, colorIndex) => (
                        <div
                          class={`color-div transform-gpu transition-transform duration-[200ms] ${
                            project.name === "Strider Intel"
                              ? "group-hover:translate-y-[20%]"
                              : ""
                          } ${project.name === "doxy.me" ? "group-hover:translate-y-[20%]" : ""} ${
                            project.name === "InMoment.com"
                              ? "translate-x-0 group-hover:-translate-y-[10%]"
                              : ""
                          } ${
                            project.name === "Yoli"
                              ? "translate-x-0 group-hover:-translate-x-[10%] group-hover:-translate-y-[10%]"
                              : ""
                          }`}
                          style={{
                            backgroundColor: color,
                            top: `${((colorIndex / 5) * 100).toFixed(2)}%`,
                            transitionDelay: `${colorIndex * 20}ms`,
                            left:
                              project.name === "Yoli"
                                ? `${((colorIndex / 5) * 100).toFixed(2)}%`
                                : undefined,
                          }}
                        />
                      ))}
                    </div>
                  )}

                  {project.svgcode?.code && (
                    <div
                      class={`view-actor absolute inset-0 transition-transform delay-[25ms] duration-500 ${
                        displayType === "background"
                          ? "group-hover:scale-100 scale-[80%] origin-center group-hover:duration-300"
                          : "group-hover:-translate-y-[28%] origin-center group-hover:duration-300"
                      }`}
                    >
                      <div
                        class="svg-parent absolute origin-center top-1/2 left-1/2 h-1/2 w-2/3 -translate-x-1/2 -translate-y-1/2 text-white"
                        set:html={sanitizeProjectSvg(project.svgcode.code)}
                      />
                    </div>
                  )}
                </div>
              )}

              {projectTitle}
            </a>
          </div>
        );
      })
    }
  </div>
</div>

<script>
  const bindEmbedFades = () => {
    document
      .querySelectorAll<HTMLIFrameElement>("[data-project-embed]:not([data-bound])")
      .forEach((frame) => {
        frame.dataset.bound = "";
        frame.addEventListener("load", () => frame.classList.add("is-loaded"), {
          once: true,
        });
      });
  };

  bindEmbedFades();
  document.addEventListener("astro:page-load", bindEmbedFades);
</script>
