---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import WavyLine from "@/src/components/WavyLine";
import LucideIcon from "@/src/components/icons/LucideIcon.astro";
import { LUCIDE_ICONS } from "@/src/components/icons/lucide";
import { GithubIcon, LinkedInIcon } from "@/src/components/icons";
---

<SiteLayout
  title="Contact - Chase Cee"
  description="Web Designer and Developer"
  ogImage="/og/contact.png"
>
  <Container>
    <div class="prose dark:prose-invert mx-auto flex flex-col gap-10">
      <div class="flex flex-col gap-10 md:flex-row md:items-center">
        <h1 class="mb-0 text-[13vw] whitespace-nowrap sm:text-[2.9rem] md:text-[3.3rem]">
          Let's talk
        </h1>
        <WavyLine client:visible />
      </div>
      <div class="m-0 mt-2 text-xl">
        <div class="m-0 grid grid-cols-2 gap-5 sm:grid-cols-3">
          <a
            href="https://github.com/chasecee/"
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose inline-flex items-center justify-center gap-x-3 rounded-[.25rem] border-0 px-6 py-3 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-[.125rem] ring-black/30 bg-black/5 dark:bg-white/5 dark:ring-white/30"
          >
            Github
            <GithubIcon size={24} />
          </a>

          <a
            href="https://www.linkedin.com/in/chasechristensen-1/"
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose inline-flex items-center justify-center gap-x-3 rounded-[.25rem] border-0 px-6 py-3 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-[.125rem] ring-black/30 bg-black/5 dark:bg-white/5 dark:ring-white/30"
          >
            LinkedIn
            <LinkedInIcon size={24} />
          </a>
          <a
            href="/ChaseChristensen-Resume-2025.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="not-prose inline-flex items-center justify-center gap-x-3 rounded-[.25rem] border-0 px-6 py-3 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-[.125rem] ring-black/30 bg-black/5 dark:bg-white/5 dark:ring-white/30"
          >
            Resume
            <LucideIcon icon={LUCIDE_ICONS.fileText} size={24} />
          </a>
        </div>
      </div>
    </div>
  </Container>
</SiteLayout>
