---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import Embed from "@/src/components/blocks/Embed";
import Spotify from "@/src/components/blocks/Spotify";
import Gallery from "@/src/components/blocks/Gallery";
import ImageGalleryLightbox from "@/src/components/gallery/ImageGalleryLightbox.astro";
import { getMusicBySlug } from "@/sanity/sanity-utils";
import { withSanityImageParams } from "@/src/utils/sanityImageParams";
import { draftFetchOptions } from "@/sanity/preview";

export const prerender = false;

const { slug } = Astro.params;
const musicSlug = typeof slug === "string" ? slug : "";

if (!musicSlug) {
  return Astro.redirect("/404");
}

const item = await getMusicBySlug(musicSlug, draftFetchOptions(Astro.locals));

if (!item) {
  return Astro.redirect("/404");
}

const draftMode = Astro.locals.draftMode === true;
const showDraftBadge = draftMode && item.isDraft;
const hasGallery = Boolean(item.gallery?.images?.length);
---

<SiteLayout
  title={`${item.bandName} - ${item.albumName} - Chase Cee`}
  description={`${item.albumName} by ${item.bandName}.`}
  ogImage="/og/home.png"
>
  <Container>
    <div class="prose prose-flow mt-10">
      {
        showDraftBadge && (
          <span class="mb-4 inline-flex rounded bg-amber-300 px-2 py-1 text-xs font-bold uppercase tracking-wide text-black">
            Draft
          </span>
        )
      }
      <h1>{item.bandName}</h1>
      <h2>{item.albumName}</h2>

      {
        item.albumArt && (
          <img
            src={withSanityImageParams(item.albumArt, {
              w: 1600,
              fit: "max",
              auto: "format",
            })}
            alt={item.albumArtAlt || `${item.albumName} album art`}
            width={1200}
            height={1200}
            class={`w-full rounded-xl ${showDraftBadge ? "ring-2 ring-amber-300 ring-offset-2 ring-offset-neutral-100 dark:ring-offset-neutral-900" : ""}`}
          />
        )
      }

      {
        item.gallery?.images && item.gallery.images.length > 0 && (
          <section class="mt-8">
            <Gallery
              images={item.gallery.images.map((image) => ({
                ...image,
                url: image.url
                  ? withSanityImageParams(image.url, {
                      w: 2400,
                      fit: "max",
                      auto: "format",
                    })
                  : undefined,
              }))}
              columns={item.gallery.columns}
              draftMode={draftMode}
            />
          </section>
        )
      }

      {
        item.links && item.links.length > 0 && (
          <section class="mt-10">
            <h3>Links</h3>
            <ul>
              {item.links.map((link) => (
                <li>
                  <a href={link.url} target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        item.embeds && item.embeds.length > 0 && (
          <section class="not-prose mt-10 flex flex-col gap-6">
            {item.embeds.map((embed) =>
              embed._type === "spotify" ? (
                <Spotify
                  url={embed.url}
                  title={embed.title}
                  size={embed.size}
                  theme={embed.theme}
                  draftMode={draftMode}
                />
              ) : (
                <Embed
                  url={embed.url}
                  title={embed.title || `${item.albumName} embed`}
                  width={embed.width}
                  aspectRatio={embed.aspectRatio}
                  ratio={embed.ratio}
                  draftMode={draftMode}
                />
              ),
            )}
          </section>
        )
      }
    </div>
  </Container>
  {hasGallery && <ImageGalleryLightbox />}
</SiteLayout>
