---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import { Body } from "@/src/components/Body";
import SanityVisualEditing from "@/src/components/sanity/SanityVisualEditing";
import { getPage } from "@/sanity/sanity-utils";
import { metaDescription } from "@/src/utils/seo";

export const prerender = false;

const { slug } = Astro.params;
const page = await getPage(slug!, { preview: true });

if (!page) {
  return Astro.redirect("/404");
}

const title = `${page.title} - Chase Cee`;
const description = metaDescription(
  page.subtitle,
  `${page.title} - Chase Cee, a designer and developer in Salt Lake City building excellent web products front to back.`,
);
---

<SiteLayout {title} {description}>
  <Container className="pt-24" showCTA={true}>
    <div class="prose dark:prose-invert mx-auto">
      <header>
        <h1>{page.subtitle ?? page.title}</h1>
      </header>
      <div class="content">
        <Body value={page.content} preview />
      </div>
    </div>
  </Container>
  <SanityVisualEditing client:only="react" />
</SiteLayout>
