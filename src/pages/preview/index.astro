---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import ContainerHome from "@/src/components/ContainerHome.astro";
import ProjectsList from "@/src/components/ProjectsList.astro";
import HomeHero9 from "@/src/components/hero/HomeHero9/HomeHero9";
import SanityVisualEditing from "@/src/components/sanity/SanityVisualEditing";
import { getPersonalProjects, getClientProjects } from "@/sanity/sanity-utils";

export const prerender = false;

const [personalProjects, clientProjects] = await Promise.all([
  getPersonalProjects({ preview: true }),
  getClientProjects({ preview: true }),
]);
---

<SiteLayout ogImage="/og/home.png">
  <ContainerHome className="relative z-10 pt-4">
    <HomeHero9 client:load />
    <div class="relative z-10 flex flex-col gap-10">
      <ProjectsList
        projects={personalProjects}
        title="Personal Projects"
        columns={3}
        preview
      />
      <ProjectsList
        projects={clientProjects}
        title="Client Work"
        columns={4}
        preview
      />
    </div>
  </ContainerHome>
  <SanityVisualEditing client:only="react" />
</SiteLayout>
