---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import { Body } from "@/src/components/Body";
import ProjectLink from "@/src/components/ProjectLink.astro";
import LucideIcon from "@/src/components/icons/LucideIcon.astro";
import { LUCIDE_ICONS } from "@/src/components/icons/lucide";
import { getProject } from "@/sanity/sanity-utils";
import urlFor from "@/sanity/sanity.image";
import { metaDescription } from "@/src/utils/seo";
import { draftFetchOptions } from "@/sanity/preview";
import { stegaClean } from "@sanity/client/stega";

export const prerender = false;

const { project: slug } = Astro.params;
const projectSlug = typeof slug === "string" ? slug : "";

if (!projectSlug) {
  return Astro.redirect("/404");
}

const { project, nextProject, prevProject } = await getProject(
  projectSlug,
  draftFetchOptions(Astro.locals),
);

if (!project) {
  return Astro.redirect("/404");
}

function shortenUrl(url: string): string {
  try {
    const urlObj = new URL(url);
    let hostname = urlObj.hostname;
    if (hostname.startsWith("www.")) {
      hostname = hostname.slice(4);
    }
    return hostname;
  } catch {
    return url.replace(/^https?:\/\/(www\.)?/, "").replace(/\/$/, "");
  }
}

const projectUrl =
  typeof project.url === "string" ? stegaClean(project.url).trim() : "";
const draftMode = Astro.locals.draftMode === true;
const showDraftBadge = draftMode && project.isDraft;
const featuredImageTransitionName = `project-featured-image-${projectSlug}`;
const overlayTransitionName = `project-hero-overlay-${projectSlug}`;
const cleanName = stegaClean(project.name);
const description = metaDescription(
  stegaClean(project.subtitle),
  `${cleanName} is a project designed and built by Chase Cee, a designer and developer in Salt Lake City.`,
);
---

<SiteLayout
  title={`${cleanName} - Chase Cee`}
  {description}
  ogImage={`/og/project/${stegaClean(project.slug)}.png`}
>
  
    <header
      class={`not-prose relative mb-0 md:aspect-[16/9] aspect-square max-h-[50vh] py-20 flex flex-col justify-end w-full ${showDraftBadge ? "ring-2 ring-amber-300 ring-inset" : ""}`}
    >
      {
        project.image && (
            <img
            src={urlFor(project.image).width(1600).height(900).dpr(1.5).url()}
            alt={cleanName}
            class="vt-image absolute inset-0 h-full w-full object-cover"
            transition:name={featuredImageTransitionName}
            loading="eager"
            fetchpriority="high"
          />
        )
      }
      <div
        class="absolute inset-0 bg-black/45"
        transition:name={overlayTransitionName}
      />
      {showDraftBadge && (
        <span class="absolute top-4 right-4 z-20 inline-flex rounded bg-amber-300 px-2 py-1 text-xs font-bold uppercase tracking-wide text-black">
          Draft
        </span>
      )}
      <div class="relative z-10 ">
        <div class="container">
          <div class="flex flex-col items-start justify-start gap-6">
          <h1 class="text-white text-6xl mb-0 leading-none">{project.name}</h1>
          {
            project.subtitle && (
              <p class="mb-1 text-lg text-white/70">{project.subtitle}</p>
            )
          }
          {
            projectUrl && (
              <a
                href={projectUrl}
                title={cleanName}
                target="_blank"
                class="group inline-flex ring-1 ring-current/50 px-4 rounded text-white no-underline hover:opacity-70"
              >
                <span class="flex h-[2.1rem] flex-row items-center justify-normal gap-1">
                  {project.archived ? "Archived: " : ""}
                  {shortenUrl(projectUrl)}
                  <LucideIcon
                    icon={LUCIDE_ICONS.externalLink}
                    size={16}
                    class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                  />
                </span>
              </a>
            )
          }
          </div>
        </div>
      </div>
    </header>
    <Container>
    <div class="prose mx-auto">
      {
        project.content && (
          <div>
            <Body value={project.content} />
          </div>
        )
      }
      <h3 class="mt-20 mb-4 text-xl">Thanks for reading! Check out more:</h3>
      <div class="not-prose grid gap-4 md:grid-cols-2">
        {prevProject && <ProjectLink project={prevProject} direction="prev" />}
        {nextProject && <ProjectLink project={nextProject} direction="next" />}
      </div>
    </div>
  </Container>
</SiteLayout>
