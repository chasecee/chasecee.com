{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./*"]
    },
    "baseUrl": "."
  },
  "include": [
    ".astro/types.d.ts",
    "global.d.ts",
    "src/**/*",
    "sanity/**/*",
    "types/**/*",
    "lib/**/*"
  ],
  "exclude": ["node_modules", "dist", "app", "studio"]
}
