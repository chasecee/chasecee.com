---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import {
  SanityVisualEditing,
  DraftModeActions,
  presentationEditUrl,
} from "@chasecee/sanity-kit/astro/visual-editing";
import { STUDIO_URL } from "@/sanity/studio-url";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Work - Chase Cee",
  description = "Chase Cee is a designer and developer in Salt Lake City building excellent web products front to back, from brand and UI design to full-stack engineering.",
  ogImage = "/api/og/home.png",
} = Astro.props;

const draftMode = Astro.locals.draftMode === true;
const editorMode = Astro.locals.editorMode === true;
const showEditorBar = draftMode || editorMode;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isHome = pathname === "/";
const siteOrigin =
  import.meta.env.DEV ? Astro.url.origin : (Astro.site ?? Astro.url.origin);
const canonicalURL = new URL(pathname, siteOrigin);
const ogImageURL = new URL(ogImage, siteOrigin);
const editUrl = presentationEditUrl(STUDIO_URL, Astro.url.href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Chase Cee" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/icons/site/favicon.ico" />
    <link rel="shortcut icon" href="/icons/site/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/icons/site/apple-touch-icon.png" />
    <Font
      cssVariable="--font-rubik"
      preload={
        isHome
          ? [{ style: "normal" }]
          : [{ style: "normal" }, { style: "italic" }]
      }
    />
    {!showEditorBar && <ClientRouter />}
  </head>
  <body
    class={`font-sans w-full min-h-screen bg-neutral-100 dark:bg-neutral-900 text-neutral-900 dark:text-white ${showEditorBar ? "pt-8" : ""}`}
  >
    {
      showEditorBar && (
        <div class="fixed max-h-8 inset-x-0 top-0 z-[100] flex items-center justify-center border-b border-amber-400/30 bg-amber-300/95 px-4 text-[.75rem] text-black dark:bg-amber-300">
          <span>{draftMode ? "Draft mode active: you are viewing unpublished content" : "Preview available for this session"}</span>
          <DraftModeActions
            client:only="react"
            mode={draftMode ? "draft" : "reenter"}
            editHref={editUrl}
            reenterLabel="Re-enter preview"
            dismissLabel="Dismiss"
            linkClassName="ml-3 underline underline-offset-2 hover:no-underline"
          />
        </div>
      )
    }
    <div id="sanity-preview-root">
      <slot />
    </div>
    <script is:inline>
      document.addEventListener(
        "load",
        (event) => {
          const target = event.target;
          if (
            target instanceof HTMLIFrameElement &&
            (target.classList.contains("embed-frame") ||
              target.classList.contains("embed-frame-fixed"))
          ) {
            target.classList.add("is-loaded");
          }
        },
        true,
      );
    </script>
    <script is:inline define:vars={{ navOrder: ["/", "/music", "/about"] }}>
      document.addEventListener("astro:before-preparation", (event) => {
        const normalizePath = (url) => {
          const path = url.pathname.replace(/\/+$/, "") || "/";
          if (path === "/about" || path.startsWith("/about/")) return "/about";
          if (path === "/music" || path.startsWith("/music/")) return "/music";
          return "/";
        };

        const fromPath = normalizePath(event.from);
        const toPath = normalizePath(event.to);
        const fromIndex = navOrder.indexOf(fromPath);
        const toIndex = navOrder.indexOf(toPath);
        if (fromIndex < 0 || toIndex < 0 || fromIndex === toIndex) return;
        event.direction = toIndex > fromIndex ? "forward" : "back";
      });
    </script>
    {draftMode && <SanityVisualEditing client:only="react" />}
  </body>
</html>
