---
import HeaderLogo from "./HeaderLogo";
import HeaderNav from "./HeaderNav.astro";
import SocialLinks from "./SocialLinks.astro";

interface Props {
  activePath: string;
}

const { activePath } = Astro.props;
---

<div class="sticky top-2 inset-x-0 z-40 overflow-visible md:top-4" transition:name="site-header" transition:animate="none">
  <header class="header container relative z-0 flex min-h-12 items-center overflow-visible py-2">
    <div aria-hidden class="header-border pointer-events-none absolute inset-0 z-1 rounded-xl border-site border-neutral-500/50 dark:border-neutral-600"></div>
    <div aria-hidden class="header-inner pointer-events-none absolute inset-(--site-border-width) z-3 rounded-[calc(var(--radius-xl)-var(--site-border-width))] bg-neutral-50 dark:bg-neutral-900"></div>
    <div class="flex shrink-0 justify-start md:w-1/3">
      <HeaderLogo client:load transition:persist="header-logo" />
      <script is:inline data-astro-rerun>
        (() => {
          const stored = localStorage.getItem("chasecee:logo-paths");
          if (!stored) return;

          try {
            const paths = JSON.parse(stored);
            const nodes = document.querySelectorAll(
              "[data-chasecee-logo] .logo-wordmark-path",
            );
            if (paths.length !== nodes.length) return;
            nodes.forEach((node, index) => node.setAttribute("d", paths[index]));
          } catch {
            localStorage.removeItem("chasecee:logo-paths");
          }
        })();
      </script>
    </div>

    <div class="relative z-10 flex flex-1 justify-end md:w-1/3 md:flex-none md:justify-center">
      <HeaderNav activePath={activePath} />
    </div>

    <div class="relative z-10 hidden shrink justify-end md:flex md:w-1/3">
      <SocialLinks />
    </div>
  </header>
</div>
