---
import Header from "@/src/components/Header";
import LucideIcon from "@/src/components/icons/LucideIcon.astro";
import { LUCIDE_ICONS } from "@/src/components/icons/lucide";
import StudioEgg from "@/src/components/StudioEgg.astro";
import { studioDocumentUrl } from "@/sanity/studio-url";

interface Props {
  className?: string;
  showCTA?: boolean;
  ctaTitle?: string;
  ctaSubtitle?: string;
  document?: { _id?: string | null; _type?: string | null } | null;
}

const {
  className = "",
  showCTA = false,
  ctaTitle = "Let's build something spectacular.",
  ctaSubtitle = "I build powerful and beautiful applications for businesses of all sizes. I'm available for work, let's get started!",
  document: sanityDocument,
} = Astro.props;

const studioHref = studioDocumentUrl(sanityDocument);
---

<div class={`root min-h-screen w-full ${className} pt-4 md:pt-8`}>
  <div class="container">
    <Header
      client:load
      transition:persist="site-header"
      activePath={Astro.url.pathname}
    />
    <main>
      <slot />
    </main>
    {
      showCTA && (
        <div
          class="bg-gradient-radial relative my-20 overflow-hidden rounded-xl from-neutral-100 to-neutral-200 dark:from-neutral-700 dark:to-neutral-800"
        >
          <div
            class="absolute inset-0 rounded-xl bg-fixed bg-repeat opacity-20"
            style="background-image: url('/noise1.webp'); background-size: 250px;"
          />
          <div class="relative px-4 py-16">
            <div class="prose mx-auto text-center">
              <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
                {ctaTitle}
              </h2>
              <p class="mx-auto mt-6 max-w-xl text-lg leading-8 opacity-90">
                {ctaSubtitle}
              </p>
              <div class="mt-10 flex flex-col items-center justify-center gap-6 sm:flex-row">
                <a
                  href="/#contact"
                  class="not-prose inline-flex items-center justify-center gap-x-3 rounded-[.25rem] border-0 px-6 py-3 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-site ring-black/30 bg-indigo-600 ring-indigo-300 dark:bg-indigo-500/20 dark:ring-indigo-300/20"
                >
                  Contact
                </a>
                <a
                  href="/about"
                  class="not-prose group inline-flex items-center justify-center gap-x-3 rounded-[.25rem] border-0 px-6 py-3 text-base text-black dark:text-white no-underline shadow-xs transition-colors ring-site ring-black/30 bg-black/5 dark:bg-white/5 dark:ring-white/30"
                >
                  About Me
                  <LucideIcon
                    icon={LUCIDE_ICONS.chevronRight}
                    size={12}
                    class="transition-transform duration-200 group-hover:translate-x-1 group-active:translate-x-1"
                  />
                </a>
              </div>
            </div>
          </div>
        </div>
      )
    }
    <footer class="site-footer mt-10 py-10">
      <div class="prose max-w-none">
        <div class="flex w-full flex-col items-start gap-2 sm:flex-row sm:flex-nowrap sm:items-center sm:justify-between sm:gap-4">
          <p
            class="footer__text text-uppercase group m-0 flex flex-row items-center gap-[0.5ch] whitespace-nowrap"
          >
            Made with
            <LucideIcon
              icon={LUCIDE_ICONS.heart}
              size={24}
              class="text-2xl transition group-hover:scale-125 group-hover:text-red-400"
            />
            by
            <a href="/about">Chase Cee</a>
          </p>
          <p class="m-0 flex items-center gap-2 whitespace-nowrap text-black/50 dark:text-white/50">
            Copyright © 2011-2099
            <StudioEgg href={studioHref} />
          </p>
        </div>
      </div>
    </footer>
  </div>
</div>
