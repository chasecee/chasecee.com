---
import type { Project } from "@/types/Project";
import generateColorPalette from "@/src/utils/colorUtils";
import urlFor from "@/sanity/sanity.image";
import { sanitizeProjectSvg } from "@/src/utils/sanitizeProjectSvg";

interface Props {
  project: Project;
  index: number;
  columns: number;
  scroll?: boolean;
  cardImageWidths: number[];
  cardImageSizes: string;
  cardImageMaxWidth: number;
}

const {
  project,
  index,
  columns,
  scroll = false,
  cardImageWidths,
  cardImageSizes,
  cardImageMaxWidth,
} = Astro.props;

const getColumnClass = (cols: number): string => {
  switch (cols) {
    case 1:
      return "w-full";
    case 2:
      return "md:w-1/2";
    case 3:
      return "md:w-1/3";
    case 4:
      return "md:w-1/4";
    case 5:
      return "md:w-1/5";
    case 6:
      return "md:w-1/6";
    default:
      return "md:w-1/4";
  }
};

const slugname = project.slug ?? undefined;
const displayType = project.displayType || "popup";
const colorPalette = project.color?.hex
  ? generateColorPalette(project.color.hex)
  : null;
const projectImage = project.image;
const parseRatio = (value: string) => {
  const compact = value.replace(/\s+/g, "");
  const normalized = compact.includes("/")
    ? compact
    : compact.includes(":")
      ? compact.replace(":", "/")
      : compact;
  if (!/^\d+(\.\d+)?\/\d+(\.\d+)?$/.test(normalized)) return { w: 1, h: 1 };
  const [w, h] = normalized.split("/").map(Number);
  return { w, h };
};
const desktopRatio = parseRatio(project.aspectRatio?.desktop || "1/1");
const mobileRatio = parseRatio(
  project.aspectRatio?.mobile || project.aspectRatio?.desktop || "1/1",
);
const draftMode = Astro.locals.draftMode === true;
const showDraftBadge = draftMode && project.isDraft;
const draftRingClass = showDraftBadge
  ? "rounded-2xl p-1 border-2 border-amber-300"
  : "";
const itemClass = scroll
  ? `project-item ${getColumnClass(columns)} w-[80%] flex-shrink-0 project-${index + 1} project-${slugname} ${draftRingClass}`
  : `project-item project-${index + 1} project-${slugname} ${draftRingClass}`;
---

<div class={itemClass}>
  <a
    href={`/projects/${slugname}`}
    title={`See my work on ${project.name}`}
    class="group"
  >
    {
      displayType === "embed" && project.embedUrl ? (
        <div
          class="project-embed"
          style={`--ar-desktop-w: ${desktopRatio.w}; --ar-desktop-h: ${desktopRatio.h}; --ar-mobile-w: ${mobileRatio.w}; --ar-mobile-h: ${mobileRatio.h};`}
        >
          {showDraftBadge && (
            <span class="pointer-events-none absolute top-2 right-2 z-20 inline-flex rounded bg-amber-300 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-black">
              Draft
            </span>
          )}
          <iframe
            title={project.name ?? undefined}
            tabindex="-1"
            data-project-embed
            data-src={project.embedUrl}
          />
        </div>
      ) : slugname === "loop-player" ? (
        <div class="relative h-0 overflow-hidden pt-[100%]">
          {showDraftBadge && (
            <span class="pointer-events-none absolute top-2 right-2 z-20 inline-flex rounded bg-amber-300 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-black">
              Draft
            </span>
          )}
          <img
            src="/img/loop-box.webp"
            alt="Loop Player product packaging"
            width={473}
            height={473}
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
          {project.svgcode?.code && (
            <div class="view-actor absolute inset-0 transition-transform duration-200 ease-[cubic-bezier(0.23,1,0.32,1)] [@media(hover:hover)_and_(pointer:fine)]:group-hover:scale-110">
              <div
                class="svg-parent absolute top-1/2 left-1/2 h-full w-[50%] -translate-x-1/2 -translate-y-1/2 text-white"
                set:html={sanitizeProjectSvg(project.svgcode.code)}
              />
            </div>
          )}
        </div>
      ) : (
        <div class="relative h-0 overflow-hidden pt-[100%]">
          {showDraftBadge && (
            <span class="pointer-events-none absolute top-2 right-2 z-20 inline-flex rounded bg-amber-300 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-black">
              Draft
            </span>
          )}
          {displayType === "background" && projectImage ? (
            <img
              src={urlFor(projectImage)
                .width(cardImageMaxWidth)
                .height(cardImageMaxWidth)
                .fit("crop")
                .dpr(1)
                .url()}
              srcset={cardImageWidths
                .map(
                  (width) =>
                    `${urlFor(projectImage)
                      .width(width)
                      .height(width)
                      .fit("crop")
                      .dpr(1)
                      .url()} ${width}w`,
                )
                .join(", ")}
              sizes={cardImageSizes}
              alt={project.name ?? ""}
              width={cardImageMaxWidth}
              height={cardImageMaxWidth}
              class="absolute inset-0 h-full w-full object-cover"
              loading={index === 0 ? "eager" : "lazy"}
              fetchpriority={index === 0 ? "high" : "auto"}
              decoding="async"
            />
          ) : (
            project.color?.hex && (
              <div
                class="absolute inset-0"
                style={{ backgroundColor: project.color.hex }}
              />
            )
          )}

          {displayType === "popup" && colorPalette && (
            <div class="project-gradient-bg absolute inset-0 -top-10 -bottom-10 flex-col flex-nowrap gap-0 overflow-hidden opacity-[20%]">
              {[
                colorPalette.darkest,
                colorPalette.darker,
                colorPalette.main,
                colorPalette.lighter,
                colorPalette.lightest,
              ].map((color, colorIndex) => (
                <div
                  class={`color-div transform-gpu transition-transform duration-200 ease-[cubic-bezier(0.23,1,0.32,1)] ${
                    project.name === "Strider Intel"
                      ? "[@media(hover:hover)_and_(pointer:fine)]:group-hover:translate-y-[20%]"
                      : ""
                  } ${project.name === "doxy.me" ? "[@media(hover:hover)_and_(pointer:fine)]:group-hover:translate-y-[20%]" : ""} ${
                    project.name === "InMoment.com"
                      ? "translate-x-0 [@media(hover:hover)_and_(pointer:fine)]:group-hover:-translate-y-[10%]"
                      : ""
                  } ${
                    project.name === "Yoli"
                      ? "translate-x-0 [@media(hover:hover)_and_(pointer:fine)]:group-hover:-translate-x-[10%] [@media(hover:hover)_and_(pointer:fine)]:group-hover:-translate-y-[10%]"
                      : ""
                  }`}
                  style={{
                    backgroundColor: color,
                    top: `${((colorIndex / 5) * 100).toFixed(2)}%`,
                    transitionDelay: `${colorIndex * 20}ms`,
                    left:
                      project.name === "Yoli"
                        ? `${((colorIndex / 5) * 100).toFixed(2)}%`
                        : undefined,
                  }}
                />
              ))}
            </div>
          )}

          {project.svgcode?.code && (
            <div
              class={`view-actor absolute inset-0 transition-transform duration-200 ease-[cubic-bezier(0.23,1,0.32,1)] ${
                displayType === "background"
                  ? "scale-[80%] origin-center [@media(hover:hover)_and_(pointer:fine)]:group-hover:scale-100"
                  : "scale-[0.95] origin-center [@media(hover:hover)_and_(pointer:fine)]:group-hover:scale-100"
              }`}
            >
              <div
                class="svg-parent absolute origin-center top-1/2 left-1/2 h-1/2 w-2/3 -translate-x-1/2 -translate-y-1/2 text-white"
                set:html={sanitizeProjectSvg(project.svgcode.code)}
              />
            </div>
          )}
        </div>
      )
    }
    <div class="relative">
      <span class="mt-3 inline-block text-base">
        <span class="font-bold">{project.name}</span>
        {
          project.subtitle && (
            <span class="font-light opacity-40">
              &nbsp;-&nbsp;{project.subtitle}
            </span>
          )
        }
      </span>
    </div>
  </a>
</div>
