---
import type { Project } from "@/types/Project";
import ProjectCard from "@/src/components/ProjectCard.astro";
import LucideIcon from "@/src/components/icons/LucideIcon.astro";
import { LUCIDE_ICONS } from "@/src/components/icons/lucide";

interface Props {
  projects: Project[];
  title?: string;
  columns?: number;
  scroll?: boolean;
  initialCount?: number;
}

const {
  projects,
  title,
  columns = 4,
  scroll = true,
  initialCount,
} = Astro.props;

const getGridClass = (cols: number): string => {
  switch (cols) {
    case 1:
      return "grid-cols-1";
    case 2:
      return "grid-cols-1 md:grid-cols-2";
    case 3:
      return "grid-cols-1 md:grid-cols-3";
    case 4:
      return "grid-cols-1 md:grid-cols-4";
    case 5:
      return "grid-cols-1 md:grid-cols-5";
    case 6:
      return "grid-cols-1 md:grid-cols-6";
    default:
      return "grid-cols-1 md:grid-cols-3";
  }
};

const getCardImageSizes = (cols: number): string => {
  switch (cols) {
    case 2:
      return "(min-width: 768px) 50vw, 80vw";
    case 3:
      return "(min-width: 768px) 33vw, 80vw";
    case 4:
      return "(min-width: 768px) 25vw, 80vw";
    case 5:
      return "(min-width: 768px) 20vw, 80vw";
    case 6:
      return "(min-width: 768px) 16vw, 80vw";
    default:
      return "(min-width: 768px) 25vw, 80vw";
  }
};

const getCardImageWidths = (cols: number): number[] => {
  switch (cols) {
    case 2:
      return [320, 480, 640, 800, 960];
    case 3:
      return [320, 480, 640, 800];
    case 4:
    case 5:
    case 6:
      return [240, 320, 480, 640];
    default:
      return [320, 480, 640, 800];
  }
};

const validProjects = projects.filter(
  (project) => project && project._id && project.name,
);
const expandable =
  typeof initialCount === "number" &&
  initialCount > 0 &&
  validProjects.length > initialCount;
const visibleProjects = expandable
  ? validProjects.slice(0, initialCount)
  : validProjects;
const restProjects = expandable
  ? validProjects.slice(initialCount)
  : [];

const cardImageWidths = getCardImageWidths(columns);
const cardImageSizes = getCardImageSizes(columns);
const cardImageMaxWidth = cardImageWidths.at(-1) ?? 640;
const gridClass = getGridClass(columns);
const listClass = scroll
  ? "flex flex-nowrap gap-12 overflow-x-auto pb-10"
  : `grid gap-8 ${gridClass}`;
---

<section
  class="project-list"
  data-projects-expand={expandable ? "" : undefined}
>
  {
    title && (
      <div
        class="mb-6 flex items-center justify-between gap-4"
        data-projects-header
      >
        <h2 class="text-left text-xl font-bold">{title}</h2>
        {expandable && (
          <button
            type="button"
            class="inline-flex items-center gap-1.5 text-sm font-medium opacity-70 transition-opacity hover:opacity-100"
            data-see-all
            aria-expanded="false"
          >
            <span data-see-all-label>See All</span>
            <span
              class="inline-flex transition-transform duration-200"
              data-see-all-icon
            >
              <LucideIcon icon={LUCIDE_ICONS.chevronDown} size={16} />
            </span>
          </button>
        )}
      </div>
    )
  }
  <div class={listClass}>
    {
      visibleProjects.map((project, index) => (
        <ProjectCard
          project={project}
          index={index}
          columns={columns}
          scroll={scroll}
          cardImageWidths={cardImageWidths}
          cardImageSizes={cardImageSizes}
          cardImageMaxWidth={cardImageMaxWidth}
        />
      ))
    }
  </div>
  {
    expandable && (
      <div
        class="grid transition-[grid-template-rows] duration-200 ease-out"
        style="grid-template-rows: 0fr"
        data-see-all-panel
      >
        <div class="min-h-0 overflow-hidden">
          <div class={`grid gap-8 pt-8 ${gridClass}`}>
            {restProjects.map((project, index) => (
              <ProjectCard
                project={project}
                index={visibleProjects.length + index}
                columns={columns}
                scroll={false}
                cardImageWidths={cardImageWidths}
                cardImageSizes={cardImageSizes}
                cardImageMaxWidth={cardImageMaxWidth}
              />
            ))}
          </div>
        </div>
      </div>
    )
  }
</section>

<script>
  const bindEmbedFades = () => {
    document
      .querySelectorAll<HTMLIFrameElement>("[data-project-embed]:not([data-bound])")
      .forEach((frame) => {
        frame.dataset.bound = "";
        const src = frame.dataset.src;
        if (!src) return;

        const reveal = () => frame.classList.add("is-loaded");
        frame.addEventListener("load", reveal, { once: true });

        const activate = () => {
          if (frame.getAttribute("src")) return;
          frame.src = src;
        };

        if (!("IntersectionObserver" in window)) {
          activate();
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            if (!entries.some((entry) => entry.isIntersecting)) return;
            io.disconnect();
            activate();
          },
          { rootMargin: "200px 0px" },
        );
        io.observe(frame);
      });
  };

  const bindSeeAll = () => {
    document
      .querySelectorAll<HTMLElement>("[data-projects-expand]:not([data-bound])")
      .forEach((root) => {
        root.dataset.bound = "";
        const button = root.querySelector<HTMLButtonElement>("[data-see-all]");
        const panel = root.querySelector<HTMLElement>("[data-see-all-panel]");
        const header = root.querySelector<HTMLElement>("[data-projects-header]");
        const label = root.querySelector<HTMLElement>("[data-see-all-label]");
        const icon = root.querySelector<HTMLElement>("[data-see-all-icon]");
        if (!button || !panel || !header) return;

        button.addEventListener("click", () => {
          const open = button.getAttribute("aria-expanded") === "true";
          const next = !open;
          const reducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;
          button.setAttribute("aria-expanded", String(next));
          if (reducedMotion) panel.style.transition = "none";
          panel.style.gridTemplateRows = next ? "1fr" : "0fr";
          if (reducedMotion) {
            panel.offsetHeight;
            panel.style.transition = "";
          }
          if (label) label.textContent = next ? "Show less" : "See All";
          icon?.classList.toggle("rotate-180", next);
          if (next) {
            header.scrollIntoView({
              behavior: reducedMotion ? "auto" : "smooth",
              block: "start",
            });
          }
        });
      });
  };

  const bind = () => {
    bindEmbedFades();
    bindSeeAll();
  };

  bind();
  document.addEventListener("astro:page-load", bind);
</script>
