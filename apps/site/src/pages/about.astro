---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import ProfilePic from "@/src/components/about/ProfilePic";
import ViewSwitcher from "@/src/components/about/skills/ViewSwitcher";
import skills from "@/src/data/skills.json";

export const prerender = false;
---

<SiteLayout
  title="About - Chase Cee"
  description="Chase Cee is a web designer and developer in Salt Lake City with over a decade of experience blending design and code into effective products."
  ogImage="/og/about.png"
>
  <Container>
    <div class="prose prose-flow mt-10">
      <div class="relative mb-10 grid w-full gap-6 md:grid-cols-3 md:items-center">
        <div class="max-w-[30rem] md:max-w-none">
          <ProfilePic client:visible />
        </div>
        <div class="not-prose md:col-span-2 md:flex md:items-center md:justify-center">
          <h1 class="relative z-20 m-0 text-[clamp(2.4rem,10vw,4.3rem)] leading-[0.95]">
            Hard worker. <br /> Fast learner.
          </h1>
        </div>
      </div>

      <p class="text-xl">
        I'm Chase, a designer and developer based in Salt Lake City, Utah.
      </p>

      <p>
        I build online experiences front to back. Effective design should be
        driven by powerful, elegant applications. Magic happens when these are
        unified under a single, beautiful brand.
      </p>
      <p>
        From nationwide organizations to growing businesses, I have the
        experience and skillset guaranteed to deliver results. I'm a front-end
        fanatic with a love for blending design and code into a platform that
        helps clients achieve their goals.
      </p>
      <h2>Curiousity is the key</h2>
      <p>
        Working freelance as a designer and developer for over a decade taught
        me to adapt and learn based off the client mandate. Over the years I've
        done just about everything, and learned a lot along the way. I am
        obsessed with learning new things.
      </p>

      <div class="mb-10">
        <ViewSwitcher client:visible skills={skills} />
      </div>

      <p>
        I'm constantly researching and evolving, whether it be for code best
        practices or keeping at the cutting edge of design trends.
      </p>
      <p>
        Overall, I just love to build things and tackle new challenges. I'm
        always open to talk about new opportunities! Let's get started on your
        next big idea —{" "}
        <a
          href="#"
          class="underline"
          data-u="chaserchristensen"
          data-d="gmail.com"
          id="about-email"
        >
          chaserchristensen [at] gmail [dot] com
        </a>.
      </p>
    </div>
  </Container>
</SiteLayout>

<script is:inline data-astro-rerun>
  (() => {
    const link = document.getElementById("about-email");
    if (!link) return;
    const address = `${link.dataset.u}@${link.dataset.d}`;
    const openMail = (event) => {
      event.preventDefault();
      window.location.href = `mailto:${address}`;
    };
    link.addEventListener("click", openMail);
    link.addEventListener("contextmenu", () => {
      link.href = `mailto:${address}`;
    });
  })();
</script>
