---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import ProjectsList from "@/src/components/ProjectsList.astro";
import ProjectView from "@/src/components/ProjectView";
import LiveProject from "@/src/components/LiveProject";
import ImageGalleryLightbox from "@/src/components/gallery/ImageGalleryLightbox.astro";
import { contentHasBlock } from "@chasecee/sanity-kit/astro";
import { getPersonalProjects } from "@/sanity/sanity-utils";
import { metaDescription } from "@/src/utils/seo";
import { draftFetchOptions } from "@/sanity/preview";
import { stegaClean } from "@sanity/client/stega";
import { loadQuery, getDraftModeProps } from "@/sanity/load-query";
import { PROJECT_QUERY } from "@/sanity/queries";
import type { ProjectViewData } from "@/src/components/ProjectView";

export const prerender = false;

const { project: slug } = Astro.params;
const projectSlug = typeof slug === "string" ? slug : "";

if (!projectSlug) {
  return Astro.rewrite("/404");
}

type ProjectPageData = ProjectViewData & {
  slug: string;
};

const initialProject = await loadQuery<ProjectPageData | null>({
  query: PROJECT_QUERY,
  params: { slug: projectSlug },
  ...getDraftModeProps(Astro.cookies),
});
const project = initialProject.data;

if (!project) {
  return Astro.rewrite("/404");
}

const draftMode = Astro.locals.draftMode === true;
const hasLightbox =
  draftMode ||
  contentHasBlock(project.content, "gallery") ||
  contentHasBlock(project.leadIn, "gallery") ||
  contentHasBlock(project.leadIn, "siteMini");
const cleanName = stegaClean(project.name);
const description = metaDescription(
  stegaClean(project.subtitle),
  `${cleanName} is a project designed and built by Chase Cee, a designer and developer in Salt Lake City.`,
);
const moreProjects = (
  await getPersonalProjects(draftFetchOptions(Astro.locals))
)
  .filter((p) => p.slug !== projectSlug)
  .slice(0, 3);
---

<SiteLayout
  title={`${cleanName} - Chase Cee`}
  {description}
  ogImage={`/og/project/${stegaClean(project.slug)}.png`}
>
  <Container document={project}>
    {
      draftMode ? (
        <LiveProject
          client:load
          query={PROJECT_QUERY}
          params={{ slug: projectSlug }}
          initial={{ ...initialProject, data: project }}
        />
      ) : (
        <ProjectView project={project} />
      )
    }
    {
      moreProjects.length > 0 && (
        <div class="prose prose-flow ">
          <div class="measure-full">
            <h3 class=" mb-6 ">Thanks for reading! Check out more:</h3>
          </div>
          <div class="measure-full not-prose">
            <ProjectsList projects={moreProjects} columns={3} scroll={false} />
          </div>
        </div>
      )
    }
  </Container>
  {hasLightbox && <ImageGalleryLightbox />}
</SiteLayout>
