---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import MusicDetail from "@/src/components/MusicDetail.astro";
import LiveMusic from "@/src/components/LiveMusic";
import ImageGalleryLightbox from "@/src/components/gallery/ImageGalleryLightbox.astro";
import { getMusicBySlug } from "@/sanity/sanity-utils";
import { draftFetchOptions } from "@/sanity/preview";
import { loadQuery, getDraftModeProps } from "@/sanity/load-query";
import { MUSIC_QUERY } from "@/sanity/queries";
import { stegaClean } from "@sanity/client/stega";
import type { MusicViewData } from "@/src/components/MusicView";
import { contentHasBlock } from "@chasecee/sanity-kit/astro";

export const prerender = false;

const { slug } = Astro.params;
const musicSlug = typeof slug === "string" ? slug : "";

if (!musicSlug) {
  return Astro.rewrite("/404");
}

const draftMode = Astro.locals.draftMode === true;

const initialMusic = draftMode
  ? await loadQuery<MusicViewData | null>({
      query: MUSIC_QUERY,
      params: { slug: musicSlug },
      ...getDraftModeProps(Astro.cookies),
    })
  : null;

const item = draftMode
  ? initialMusic?.data
  : await getMusicBySlug(musicSlug, draftFetchOptions(Astro.locals));

if (!item) {
  return Astro.rewrite("/404");
}

const hasGallery = contentHasBlock(item.content, "gallery");
const bandName = stegaClean(item.bandName);
const albumName = stegaClean(item.albumName);
---

<SiteLayout
  title={`${albumName} by ${bandName} - Chase Cee`}
  description={`${albumName} by ${bandName}.`}
  ogImage="/og/home.png"
>
  <Container document={item}>
    {
      draftMode && initialMusic ? (
        <LiveMusic
          client:load
          query={MUSIC_QUERY}
          params={{ slug: musicSlug }}
          initial={{ ...initialMusic, data: item }}
        />
      ) : (
        <MusicDetail item={item} />
      )
    }
  </Container>
  {hasGallery && <ImageGalleryLightbox />}
</SiteLayout>
