---
import SiteLayout from "@/src/layouts/SiteLayout.astro";
import Container from "@/src/components/Container.astro";
import { Body } from "@/src/components/Body";
import ImageGalleryLightbox from "@/src/components/gallery/ImageGalleryLightbox.astro";
import { contentHasBlock } from "@chasecee/sanity-kit/astro";
import { getPage } from "@/sanity/sanity-utils";
import urlFor from "@/sanity/sanity.image";
import { metaDescription } from "@/src/utils/seo";
import type { PAGE_QUERY_RESULT } from "@/sanity/sanity.types";
import type { SanityImageSource } from "@sanity/image-url";
import { stegaClean } from "@sanity/client/stega";
import { draftFetchOptions } from "@/sanity/preview";

export const prerender = false;

type PageContent = NonNullable<NonNullable<PAGE_QUERY_RESULT>["content"]>[number];
type PageImageBlock = Extract<PageContent, { _type: "image" }>;

const { slug } = Astro.params;
const page = await getPage(slug!, draftFetchOptions(Astro.locals));

if (!page) {
  return Astro.rewrite("/404");
}

const title = `${page.title} - Chase Cee`;
const description = metaDescription(
  page.subtitle,
  `${page.title} - Chase Cee, a designer and developer in Salt Lake City building excellent web products front to back.`,
);
const content = page.content ?? [];
const heroImage =
  content.find((block): block is PageImageBlock => block._type === "image") ??
  null;
const contentWithoutHero = heroImage
  ? content.filter((block) => block !== heroImage)
  : content;
const heroTitle = page.subtitle ?? page.title;
const heroImageTransitionName = `page-hero-image-${page.slug}`;
const heroImageSrc = heroImage
  ? urlFor(heroImage as SanityImageSource).width(1600).fit("max").url()
  : "";
const heroImageAlt =
  heroImage && typeof heroImage.alt === "string"
    ? stegaClean(heroImage.alt).trim()
    : page.title;
const draftMode = Astro.locals.draftMode === true;
const hasLightbox =
  draftMode ||
  contentHasBlock(contentWithoutHero, "gallery");
---

<SiteLayout {title} {description}>
  <Container className="pt-24" showCTA={true} document={page}>
    <div class="prose prose-flow">
      <header class="not-prose relative mb-10 min-h-52 overflow-hidden rounded-xl bg-neutral-900 sm:min-h-64">
        {
          heroImageSrc && (
            <img
              src={heroImageSrc}
              alt={heroImageAlt || page.title}
              class="absolute inset-0 h-full w-full scale-105 object-cover"
              transition:name={heroImageTransitionName}
            />
          )
        }
        <div class="absolute inset-0 bg-black/45" />
        <div class="relative z-10 mx-auto flex min-h-52 w-full items-center px-6 sm:min-h-64 sm:px-8">
          <div class="w-full max-w-prose">
            <h1 class="m-0 text-white">{heroTitle}</h1>
          </div>
        </div>
      </header>
      <Body value={contentWithoutHero} draftMode={draftMode} />
    </div>
  </Container>
  {hasLightbox && <ImageGalleryLightbox />}
</SiteLayout>
