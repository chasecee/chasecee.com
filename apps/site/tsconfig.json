{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["astro/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "global.d.ts",
    "src/**/*",
    "sanity/**/*",
    "types/**/*",
    "lib/**/*"
  ],
  "exclude": ["node_modules", "dist", "app", "studio"]
}
